{
  "expo": {
    "name": "Medossier",
    "slug": "medossier",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#40ed0c"
    },
    "android": {
      "package": "com.medossier.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#40ed0c"
      }
    },
    "ios": {
      "supportsTablet": false
    },
    "plugins": [
      "expo-router"
    ]
  }
}